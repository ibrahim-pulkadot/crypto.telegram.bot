# Telegram bot token (BotFather'dan alınır)
TELEGRAM_BOT_TOKEN=buraya_telegram_token

# OpenAI uyumlu LLM API anahtarı (sk- ile başlar)
LLM_API_KEY=sk-...

# API adresi — OpenAI uyumlu herhangi bir sağlayıcı
LLM_BASE_URL=https://api.openai.com/v1

# Kullanılacak model (vision/görsel destekli olmalı)
LLM_MODEL=gpt-4o-mini

# Ana model başarısız olursa denenecek yedekler (virgülle, opsiyonel)
LLM_FALLBACK_MODELS=

# Bot kimliği / kişiliği (opsiyonel) — LLM'in cevap tonunu belirler.
# Örn: "Sakin, öğretici bir analistsin. Emoji az kullan, gerekçeni açıkla."
BOT_NAME=Kripto Analiz Botu
BOT_PERSONA=

# Erişim kontrolü (opsiyonel) — doluysa YALNIZCA bu Telegram user id'leri botu kullanabilir.
# Boş bırakırsan bot herkese açıktır. Kendi id'ni öğrenmek için Telegram'da @userinfobot'a yaz.
# Virgülle birden fazla id girebilirsin: 123456789,987654321
ALLOWED_USER_IDS=

# Borsa (ccxt id): binance, bybit, okx, kucoin ...
EXCHANGE_ID=binance

# Analiz edilecek varsayılan zaman aralıkları (virgülle)
TIMEFRAMES=1h,4h,1d

# Her zaman aralığı için çekilecek mum sayısı
CANDLE_LIMIT=200

# Kullanıcı başına dakikada izin verilen istek sayısı
RATE_LIMIT_PER_MIN=5
